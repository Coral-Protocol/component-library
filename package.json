{
  "name": "@coral-os/component-library",
  "version": "1.3.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Coral-Protocol/component-library.git"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:e2e": "playwright test",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:unit": "vitest"
  },
  "files": [
    "src/lib",
    "!src/test",
    "!src/**/*.test.*",
    "!src/**/*.spec.*"
  ],
  "sideEffects": false,
  "type": "module",
  "svelte": "./src/lib/index.ts",
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "svelte": "./src/lib/index.ts",
      "default": "./src/lib/index.ts"
    },
    "./theme.css": "./src/lib/theme.css",
    "./*": "./src/lib/*",
    "./hooks/*": "./src/lib/hooks/*",
    "./components/*": "./src/lib/components/*",
    "./ui/*": "./src/lib/components/ui/*"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.16.0",
    "runed": "^0.28.0",
    "svelte": "^5.0.0",
    "virtua": "^0.48.5"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.2",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.7.0",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22",
    "@vitest/browser-playwright": "^4.1.0",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "formsnap": "^2.0.1",
    "globals": "^17.3.0",
    "mode-watcher": "^1.0.8",
    "paneforge": "1.0.0-next.5",
    "phosphor-icons-svelte": "^2.0.9",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "publint": "^0.3.17",
    "runed": "^0.28.0",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "svelte-sonner": "^1.0.5",
    "sveltekit-superforms": "^2.28.1",
    "tailwind-merge": "^3.0.2",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "virtua": "^0.48.5",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "vitest-browser-svelte": "^2.0.2"
  },
  "keywords": [
    "svelte"
  ]
}
